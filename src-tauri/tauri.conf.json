{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Patty",
  "version": "1.2.12",
  "identifier": "com.patty.app",
  "build": {
    "frontendDist": "../out/renderer",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Patty",
        "width": 1280,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "resizable": true,
        "dragDropEnabled": false,
        "backgroundColor": "#0f0f12"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "../resources/icon.ico"
    ],
    "resources": {
      "../resources/patty-hook.ps1": "resources/patty-hook.ps1",
      "../resources/opencode-patty-plugin.ts": "resources/opencode-patty-plugin.ts",
      "../scripts/shell-integration/pwsh.ps1": "scripts/shell-integration/pwsh.ps1",
      "../scripts/shell-integration/cmd-prompt.cmd": "scripts/shell-integration/cmd-prompt.cmd"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
